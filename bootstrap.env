# ------------------------------------------------------------------
# VPS bootstrap configuration. Override via cloud-init write_files
# or by exporting variables before running the scripts.
# ------------------------------------------------------------------

# --- Identity ---
VPS_USER="${VPS_USER:-pink}"
VPS_USER_SHELL="${VPS_USER_SHELL:-/bin/bash}"
VPS_HOSTNAME="${VPS_HOSTNAME:-}"                # empty -> auto/keep
VPS_HOSTNAME_PREFIX="${VPS_HOSTNAME_PREFIX:-vps}"
VPS_ROLE="${VPS_ROLE:-staging}"                 # staging | production | dev

# --- SSH key sources (any/all) ---
SSH_ID="${SSH_ID:-}"                            # https://sshid.io/<id>
SSH_GH_USER="${SSH_GH_USER:-}"                  # https://github.com/<u>.keys
SSH_AUTHORIZED_KEYS="${SSH_AUTHORIZED_KEYS:-}"  # raw, newline-separated

# --- Sudo ---
ENABLE_PASSWORDLESS_SUDO="${ENABLE_PASSWORDLESS_SUDO:-1}"

# --- Homebrew + tooling ---
INSTALL_BREW="${INSTALL_BREW:-1}"
INSTALL_BREW_PACKAGES="${INSTALL_BREW_PACKAGES:-1}"
BREW_PACKAGES="${BREW_PACKAGES:-starship eza tldr zoxide btop fd ripgrep bat git-delta lazygit glow ranger jq yq fzf gh node bun pnpm yarn go}"
INSTALL_NODE_LTS="${INSTALL_NODE_LTS:-0}"        # 0 because we install node via brew
INSTALL_DOCKER="${INSTALL_DOCKER:-0}"
NVM_VERSION="${NVM_VERSION:-v0.40.3}"

# --- SSH hardening ---
SSH_PORT="${SSH_PORT:-22}"
HARDEN_SSH="${HARDEN_SSH:-1}"
ALLOW_PASSWORD_AUTH="${ALLOW_PASSWORD_AUTH:-no}"
PERMIT_ROOT_LOGIN="${PERMIT_ROOT_LOGIN:-prohibit-password}"
LIMIT_SSH_TO_ADMIN_USER="${LIMIT_SSH_TO_ADMIN_USER:-1}"
DISABLE_IPV6_SSH="${DISABLE_IPV6_SSH:-0}"

# --- Firewall / fail2ban / updates / sysctl ---
ENABLE_UFW="${ENABLE_UFW:-1}"
PUBLIC_SSH_ALLOWED="${PUBLIC_SSH_ALLOWED:-1}"   # set to 0 on 2nd run to lock to tailnet
ALLOW_HTTP_HTTPS="${ALLOW_HTTP_HTTPS:-0}"
EXTRA_UFW_PORTS="${EXTRA_UFW_PORTS:-}"          # e.g. "8080/tcp 5432/tcp"
ENABLE_FAIL2BAN="${ENABLE_FAIL2BAN:-1}"
ENABLE_UNATTENDED="${ENABLE_UNATTENDED:-1}"
UNATTENDED_AUTOREBOOT="${UNATTENDED_AUTOREBOOT:-true}"
UNATTENDED_AUTOREBOOT_TIME="${UNATTENDED_AUTOREBOOT_TIME:-03:30}"
ENABLE_SYSCTL_HARDENING="${ENABLE_SYSCTL_HARDENING:-1}"
DISABLE_IPV6="${DISABLE_IPV6:-0}"

# --- Tailscale ---
INSTALL_TAILSCALE="${INSTALL_TAILSCALE:-1}"
TAILSCALE_AUTHKEY="${TAILSCALE_AUTHKEY:-}"      # tskey-auth-...
TAILSCALE_HOSTNAME="${TAILSCALE_HOSTNAME:-}"    # default = $VPS_HOSTNAME
TAILSCALE_TAGS="${TAILSCALE_TAGS:-tag:vps}"
TAILSCALE_SSH="${TAILSCALE_SSH:-1}"
TAILSCALE_ACCEPT_DNS="${TAILSCALE_ACCEPT_DNS:-false}"
TAILSCALE_ADVERTISE_ROUTES="${TAILSCALE_ADVERTISE_ROUTES:-}"
TAILSCALE_EXIT_NODE="${TAILSCALE_EXIT_NODE:-0}"
TAILSCALE_EXTRA_ARGS="${TAILSCALE_EXTRA_ARGS:---accept-routes}"